# ---------- Secrets ----------
.env                   # local env with private keys, RPC URLs, etc.

# ---------- Build artifacts ----------
out/                   # compiled JSON, ABI, etc.
cache/                 # solidity file cache, test failures

# ---------- Hard‑hat / Foundry caches ----------
coverage/              # generated coverage reports (if used)
coverage.json
coverage.lcov

# ---------- Deployment artefacts ----------
deployments/*.json     # autogenerated deployment addresses per chain

# ---------- Packages ----------
node_modules/          # if you ever use npm/Yarn for scripts
lib/forge-std/         # optional – can be a submodule or installed via forge
lib/openzeppelin-contracts/  # same as above; keep only .gitmodules reference

# ---------- Misc ----------
*.log                  # any log files
*.tmp                  # temporary files
.DS_Store              # macOS metadata
.idea/                 # JetBrains IDE project files
.vscode/               # VSCode workspace settings
*.sublime-workspace
*.sublime-project

# ---------- Solidity specific ----------
*.solc                # compiled solidity binaries (rare)
*.snap                 # Foundry snapshot files
